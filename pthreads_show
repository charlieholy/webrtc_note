#include <stdio.h>
#include <fcntl.h>
#include <unistd.h>

int main(int argc, char *argv[]) {
    int pid = atoi(argv[1]);
    int fd = open("/dev/mythread", O_RDWR);

    read(fd, &pid, sizeof(pid));
    close(fd);
    return 0;
}
